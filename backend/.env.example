# Copy to `.env` and adjust as needed.

# How fast simulated time runs relative to real time.
# 1.0  = real time (a real day takes a real day)
# 60.0 = 1 real second is 1 simulated minute (a full day passes in 24 real minutes)
# Used so a short demo can show office hours, after-hours, and alerts firing.
SIM_SPEED=60.0

# Sim clock start time (24h HH:MM). Handy to start the demo just before 5 PM
# so the "after hours" alerts appear quickly. Leave blank to start at real now.
SIM_START=08:45

# Seconds between simulator ticks (real seconds).
SIM_TICK_SECONDS=2.0

# CORS origin for the React dev server.
FRONTEND_ORIGIN=http://localhost:5173
